# ── Spotify (Client Credentials flow — public catalog data only) ────────
# Create an app at https://developer.spotify.com/dashboard
# Used server-side only (never shipped to the client) to fetch official
# album artwork and real track links/embeds.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Supabase (durable share links) ───────────────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql
# in the SQL editor. Without these, shares fall back to a local file store
# (fine for dev; use Supabase in production).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
